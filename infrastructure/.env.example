# Langfuse Infrastructure — Environment Variables
# Copy to .env and fill in production values:
#   cp .env.example .env

# ── Langfuse Auth ──────────────────────────────────────────────
# Generate secrets: openssl rand -base64 32
NEXTAUTH_SECRET=
SALT=
# 64-char hex string: openssl rand -hex 32
ENCRYPTION_KEY=
# External URL for Langfuse web UI
NEXTAUTH_URL=http://localhost:3100

# ── Langfuse Init Project ─────────────────────────────────────
# API keys for the auto-created project
LANGFUSE_INIT_PUBLIC_KEY=pk-lf-maestro-prod
LANGFUSE_INIT_SECRET_KEY=sk-lf-maestro-prod
# Admin login
LANGFUSE_ADMIN_EMAIL=admin@local.dev
LANGFUSE_ADMIN_PASSWORD=

# ── Postgres ───────────────────────────────────────────────────
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=
POSTGRES_DB=langfuse

# ── ClickHouse ─────────────────────────────────────────────────
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── MinIO (S3-compatible object store) ─────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=

# ── Grafana ────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=http://localhost:3200
# Discord webhook for alert notifications (optional)
GRAFANA_DISCORD_WEBHOOK_URL=

# ── Maestro (profile-gated) ───────────────────────────────────
TRACING_BACKEND=langfuse
MINIMAX_API_KEY=
