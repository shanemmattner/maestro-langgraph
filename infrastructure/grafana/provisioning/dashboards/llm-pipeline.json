          "rawSql": "SELECT\n  name,\n  quantile(0.5)(dateDiff('millisecond', start_time, end_time)) AS p50,\n  quantile(0.95)(dateDiff('millisecond', start_time, end_time)) AS p95\nFROM observations\nWHERE is_deleted = 0\n  AND end_time IS NOT NULL\n  AND name NOT LIKE 'gen_ai.fallback:%'\n  AND name LIKE 'gen_ai.%'\n  AND start_time >= now() - INTERVAL 24 HOUR\nGROUP BY name\nORDER BY p50 DESC",
